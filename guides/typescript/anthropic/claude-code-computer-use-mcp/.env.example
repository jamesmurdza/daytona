# Daytona API Key - Get from https://app.daytona.io/dashboard/keys
DAYTONA_API_KEY=your_daytona_api_key_here

# Anthropic API Key - Get from https://console.anthropic.com/settings/keys
# Used for both local orchestration and sandbox agents
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Separate API key for agents running inside the sandbox
# If not provided, ANTHROPIC_API_KEY will be used
SANDBOX_ANTHROPIC_API_KEY=your_sandbox_anthropic_api_key_here
